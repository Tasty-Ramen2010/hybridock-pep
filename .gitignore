.*.npy

# Development tooling — internal planning and Claude Code config
.planning/
.claude/
CLAUDE.md

# Backup and working data files (keep only canonical data/ files)
data/calibration_*backup*.json
data/calibration_backup*.json
data/training_scores_*.json
data/pdbs/abcd.pdb
data/pdbs/pfldh_tetramer_peptide_complex*.pdb

# One-off working scripts with machine-specific paths
scripts/prep_complex_openmm.py

# RAPiDock benchmark datasets — large binary structure files (~1.5 GB total)
# not committed to git; reproduce from manifests using:
#   python scripts/download_from_manifests.py
# The manifests, raw_pdbs (training complexes), and metadata are committed.
datasets/*/structures/
datasets/cache/
datasets/training_expanded_structures/

# These are explicitly allowed (override the patterns above via negation):
# - datasets/raw_pdbs/         (18 MB gold-standard training PDBs, needed for Tier 0.4)
# - datasets/*/manifest.csv    (download manifests — recreate structure dirs on new machine)
# - datasets/pepset/           (held-out test set metadata)
# - datasets/*.txt / *.md      (metadata, bad-entry lists, validation reports)

# RAPiDock copies (large external repo — not redistributed)
third_party/RAPiDock/
third_party/RAPiDock_finetuned/

# Local clones of external repos (not redistributed here)
# hybridock-pep/ = local clone of Tasty-Ramen2010/hybridock-pep (public GitHub mirror)
hybridock-pep/
# RAPiDock-Reloaded/ = local working clone; canonical copy is at third_party/RAPiDock/
RAPiDock-Reloaded/

